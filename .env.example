OPENAI_API_KEY=

ECON_SIM_DUMMY_OPENAI=false
ECON_SIM_RUNS_DIR=runs
ECON_SIM_ALLOW_ORIGINS=["http://localhost:5173"]

ECON_SIM_ORCHESTRATOR_MODEL=gpt-5.5
ECON_SIM_ORCHESTRATOR_REASONING_EFFORT=medium
ECON_SIM_NARRATION_MODEL=gpt-5.5
ECON_SIM_NARRATION_REASONING_EFFORT=low
ECON_SIM_DEBATE_MODEL=gpt-5.5
ECON_SIM_DEBATE_REASONING_EFFORT=low
ECON_SIM_PERSONA_UPDATE_MODEL=gpt-5.5
ECON_SIM_POLL_MODEL=gpt-5.5
ECON_SIM_TRACKING_POLL_SOFT_TIMEOUT_SECONDS=45
ECON_SIM_SERVICE_TIER=priority

ECON_SIM_REALTIME_MODEL=gpt-realtime-alpha-dolphin-11
ECON_SIM_REALTIME_REASONING_EFFORT=low
# Roll back instantly if Dolphin access flakes:
# ECON_SIM_REALTIME_MODEL=gpt-realtime-1.5
# ECON_SIM_REALTIME_REASONING_EFFORT=none
ECON_SIM_REALTIME_VOICE=alloy
ECON_SIM_SPEECH_MODEL=gpt-4o-mini-tts
ECON_SIM_IMAGE_MODEL=gpt-image-2
ECON_SIM_IMAGE_SIZE=1536x1024
ECON_SIM_IMAGE_QUALITY=medium
