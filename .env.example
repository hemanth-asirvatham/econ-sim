OPENAI_API_KEY=

ECON_SIM_DUMMY_OPENAI=false
ECON_SIM_RUNS_DIR=runs
ECON_SIM_ALLOW_ORIGINS=["http://localhost:5173"]

ECON_SIM_ORCHESTRATOR_MODEL=gpt-5.4
ECON_SIM_ORCHESTRATOR_REASONING_EFFORT=high
ECON_SIM_NARRATION_MODEL=gpt-5.4
ECON_SIM_NARRATION_REASONING_EFFORT=low
ECON_SIM_DEBATE_MODEL=gpt-5.4
ECON_SIM_DEBATE_REASONING_EFFORT=low
ECON_SIM_PERSONA_UPDATE_MODEL=gpt-5.4
ECON_SIM_POLL_MODEL=gpt-5.4

ECON_SIM_REALTIME_MODEL=gpt-realtime
ECON_SIM_REALTIME_VOICE=alloy
ECON_SIM_SPEECH_MODEL=gpt-4o-mini-tts
ECON_SIM_IMAGE_MODEL=gpt-image-1.5
ECON_SIM_IMAGE_SIZE=1536x1024
ECON_SIM_IMAGE_QUALITY=high

